# ============================================================
# Root .gitignore for willkemedge-dashboard monorepo
# ============================================================

# ----- OS / IDE -----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json
*.swp
*.swo
*~

# ----- Environment files (NEVER COMMIT) -----
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
secrets.json
credentials.json

# ----- Logs -----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================
# Python / Django (backend/)
# ============================================================
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/**/*.py[cod]
backend/*$py.class
backend/**/*$py.class
backend/.Python
backend/venv/
backend/.venv/
backend/env/
backend/ENV/
backend/build/
backend/dist/
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/
backend/coverage.xml
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/static_collected/
backend/celerybeat-schedule
backend/celerybeat.pid

# ============================================================
# Node / React (frontend/)
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/
frontend/.next/
frontend/.turbo/
frontend/.eslintcache
frontend/*.tsbuildinfo
frontend/.cache/
