# Copy to .env and fill in real values. Never commit .env.

# Django core
DJANGO_SECRET_KEY=replace-me-with-a-long-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite in dev)
DATABASE_URL=

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# CORS — set to your Vercel frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL — used in password reset emails
FRONTEND_URL=http://localhost:5173

# ── M-Pesa Daraja ──────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
# sandbox | production
MPESA_ENV=sandbox
# Public HTTPS URLs Safaricom will POST to (use ngrok in dev)
MPESA_CONFIRM_URL=https://your-ngrok-id.ngrok.io/api/payments/mpesa/confirm/
MPESA_VALIDATE_URL=https://your-ngrok-id.ngrok.io/api/payments/mpesa/validate/

# ── Bank webhook ───────────────────────────────────────────────────────────
# HMAC-SHA256 secret shared with your bank
BANK_WEBHOOK_SECRET=
# Optional: bank API key for polling fallback
BANK_API_KEY=

# ── Africa's Talking (SMS) ─────────────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=

# ── SendGrid (email) ───────────────────────────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@willkemedge.co.ke
